@model TransactionFilterViewModel

<div class="page-header">
    <h1>Filter Transactions</h1>
    <p>Search your transactions by category or date range.</p>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="FilterTransactions">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label asp-for="Category" class="form-label">Category</label>
                    <input asp-for="Category" class="form-control" placeholder="e.g. Food" />
                </div>
                <div class="col-md-3">
                    <label asp-for="StartDate" class="form-label">Start date</label>
                    <input type="date" asp-for="StartDate" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="EndDate" class="form-label">End date</label>
                    <input type="date" asp-for="EndDate" class="form-control" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i>Filter
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.FilteredTransactions != null && Model.FilteredTransactions.Any())
{
    <div class="card">
        <div class="card-header">Results</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th>Amount</th>
                            <th>Category</th>
                            <th>Date</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.FilteredTransactions)
                        {
                            <tr>
                                <td>@t.Description</td>
                                <td>@t.Amount.ToString("C")</td>
                                <td>@t.Category</td>
                                <td>@t.Date.ToString("MMM d, yyyy")</td>
                                <td>
                                    @if (t.TransactionType?.ToLower() == "income")
                                    {
                                        <span class="badge badge-income">Income</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-expense">Expense</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:2rem;"></i>
            <p class="mt-2 mb-0">No transactions match your filters.</p>
        </div>
    </div>
}