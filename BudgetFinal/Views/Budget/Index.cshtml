@model BudgetViewModel

<div class="page-header">
    <h1>Dashboard</h1>
    <p>Your financial overview at a glance.</p>
</div>

<!-- Alerts -->
@if (TempData["ExpenseAlert"] != null && (bool)TempData["ExpenseAlert"])
{
    <div class="alert alert-danger d-flex align-items-center mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        Your expenses have exceeded your income.
    </div>
}
@if (TempData["BudgetAlert"] != null)
{
    <div class="alert alert-warning d-flex align-items-center mb-3" role="alert">
        <i class="bi bi-info-circle-fill me-2"></i>
        @TempData["BudgetAlert"]
    </div>
}

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:#ecfdf5;color:#059669;">
                <i class="bi bi-arrow-down-circle"></i>
            </div>
            <div class="stat-label">Income</div>
            <div class="stat-value" style="color:#059669;">@Model.TotalIncome.ToString("C")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fef2f2;color:#dc2626;">
                <i class="bi bi-arrow-up-circle"></i>
            </div>
            <div class="stat-label">Expenses</div>
            <div class="stat-value" style="color:#dc2626;">@Model.TotalExpenses.ToString("C")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:#eff6ff;color:#2563eb;">
                <i class="bi bi-cash-stack"></i>
            </div>
            <div class="stat-label">Balance</div>
            <div class="stat-value">@Model.Balance.ToString("C")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fefce8;color:#ca8a04;">
                <i class="bi bi-shield-check"></i>
            </div>
            <div class="stat-label">Threshold</div>
            <div class="stat-value">@Model.MinimumBudgetThreshold.ToString("C")</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Chart -->
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header">Income vs. Expenses</div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <div class="chart-container">
                    <canvas id="budgetChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-header">Add Transaction</div>
            <div class="card-body">
                <form asp-action="AddTransaction" method="post">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NewTransaction.Description" class="form-label">Description</label>
                            <input asp-for="NewTransaction.Description" class="form-control" placeholder="e.g. Groceries" />
                            <span asp-validation-for="NewTransaction.Description" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewTransaction.Amount" class="form-label">Amount</label>
                            <input asp-for="NewTransaction.Amount" class="form-control" placeholder="0.00" />
                            <span asp-validation-for="NewTransaction.Amount" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NewTransaction.Date" class="form-label">Date</label>
                            <input asp-for="NewTransaction.Date" type="date" class="form-control" />
                            <span asp-validation-for="NewTransaction.Date" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NewTransaction.Category" class="form-label">Category</label>
                            <input asp-for="NewTransaction.Category" class="form-control" placeholder="e.g. Food" />
                            <span asp-validation-for="NewTransaction.Category" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-plus-lg me-1"></i>Add
                            </button>
                        </div>
                    </div>
                </form>

                <hr class="my-3" />

                <form asp-action="SetMinimumThreshold" method="post">
                    <div class="row g-3 align-items-end">
                        <div class="col">
                            <label for="MinimumBudgetThreshold" class="form-label">Minimum threshold</label>
                            <input type="number" step="0.01" class="form-control" id="MinimumBudgetThreshold"
                                   name="MinimumBudgetThreshold" value="@Model.MinimumBudgetThreshold" />
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-outline-primary">Update</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Transactions Table -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Transactions</span>
        <div>
            <a href="@Url.Action("FilterTransactions", "Budget")" class="btn btn-sm btn-outline-secondary me-1">
                <i class="bi bi-funnel me-1"></i>Filter
            </a>
            <a href="@Url.Action("CreateBudget", "Budget")" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-plus-lg me-1"></i>New Budget
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Amount</th>
                        <th>Type</th>
                        <th>Category</th>
                        <th>Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Transactions ?? new List<Transaction>())
                    {
                        <tr>
                            <td>@t.Description</td>
                            <td>@t.Amount.ToString("C")</td>
                            <td>
                                @if (t.TransactionType?.ToLower() == "income")
                                {
                                    <span class="badge badge-income">Income</span>
                                }
                                else
                                {
                                    <span class="badge badge-expense">Expense</span>
                                }
                            </td>
                            <td>@t.Category</td>
                            <td>@t.Date.ToString("MMM d, yyyy")</td>
                            <td class="text-end">
                                <a href="@Url.Action("UpdateTransaction", "Budget", new { id = t.Id })"
                                   class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                                <form asp-action="DeleteTransaction" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Delete this transaction?');">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        new Chart(document.getElementById('budgetChart'), {
            type: 'doughnut',
            data: {
                labels: ['Income', 'Expenses'],
                datasets: [{
                    data: [@Model.TotalIncome, @Math.Abs(Model.TotalExpenses)],
                    backgroundColor: ['#059669', '#dc2626'],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                cutout: '65%',
                plugins: {
                    legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true, font: { size: 12 } } }
                }
            }
        });
    });
</script>
