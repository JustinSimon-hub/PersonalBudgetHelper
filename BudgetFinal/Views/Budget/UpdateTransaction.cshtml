@model BudgetFinal.Models.BudgetViewModel

<div class="page-header">
    <h1>Edit Transaction</h1>
    <p>Update the details of this transaction.</p>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form asp-controller="Budget" asp-action="UpdateTransaction" asp-route-id="@Model.NewTransaction.Id" method="post">
                    <input type="hidden" asp-for="NewTransaction.Id" />
                    <div class="mb-3">
                        <label asp-for="NewTransaction.Description" class="form-label">Description</label>
                        <input asp-for="NewTransaction.Description" class="form-control" />
                        <span asp-validation-for="NewTransaction.Description" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewTransaction.Amount" class="form-label">Amount</label>
                        <input type="number" step="0.01" asp-for="NewTransaction.Amount" class="form-control" />
                        <span asp-validation-for="NewTransaction.Amount" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewTransaction.Date" class="form-label">Date</label>
                        <input type="date" asp-for="NewTransaction.Date" class="form-control" />
                        <span asp-validation-for="NewTransaction.Date" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewTransaction.Category" class="form-label">Category</label>
                        <input asp-for="NewTransaction.Category" class="form-control" />
                        <span asp-validation-for="NewTransaction.Category" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
